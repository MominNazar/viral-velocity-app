# Copy to .env and adjust as needed
PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
JWT_REMEMBER_EXPIRES_IN=30d

# Persist data directory (Render disk mount). Example: /var/data
# DATA_DIR=/var/data

# Free Upstash Redis backup — keeps data when Render free tier sleeps
# Create DB at https://console.upstash.com → Redis → REST API
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...
# BACKUP_INTERVAL_MINUTES=2

# Free trial rules (FR-6)
TRIAL_DAYS=30
TRIAL_PHOTO_LIMIT=5

# OTP / security (NFR-6)
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_WINDOW_MINUTES=15

MODERATION_TOLERANCE=70
DATA_RETENTION_DAYS=30

# SMTP / email for OTP delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Viral Velocity <no-reply@viralvelocity.app>
RESEND_API_KEY=

ENHANCE_ENGINE=sharp
REPLICATE_API_TOKEN=
PUBLIC_BASE_URL=
