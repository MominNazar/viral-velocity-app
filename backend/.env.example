# Copy to .env and adjust as needed
PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
JWT_REMEMBER_EXPIRES_IN=30d

# Free trial rules (FR-6)
TRIAL_DAYS=30
TRIAL_PHOTO_LIMIT=5

# OTP / security (NFR-6)
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_WINDOW_MINUTES=15

# Content moderation tolerance 0-100 (NFR-10); higher = more permissive
MODERATION_TOLERANCE=70

# Data self-deletion default window (NFR-8) in days
DATA_RETENTION_DAYS=30

# SMTP / email (required for real OTP inbox delivery on Render)
# Gmail App Password:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#   MAIL_FROM=Viral Velocity <you@gmail.com>
# Or Resend (https://resend.com):
#   RESEND_API_KEY=re_xxxx
#   MAIL_FROM=Viral Velocity <onboarding@resend.dev>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Viral Velocity <no-reply@viralvelocity.app>
RESEND_API_KEY=
# Enhancement engine: sharp (free, default) or replicate (paid API + token)
ENHANCE_ENGINE=sharp
# Optional: Replicate API only when ENHANCE_ENGINE=replicate
REPLICATE_API_TOKEN=
